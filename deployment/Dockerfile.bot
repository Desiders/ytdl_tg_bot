FROM alpine:3.22 AS base
RUN apk add --no-cache \
        bash \
        ca-certificates \
    && rm -rf /var/cache/apk/*

FROM rust:1.91 AS build
RUN apt update && apt install -y musl-tools protobuf-compiler upx && rm -rf /var/lib/apt/lists/*
RUN rustup target add x86_64-unknown-linux-musl

WORKDIR /usr/src/app

COPY bot/Cargo.toml bot/Cargo.toml
COPY proto/Cargo.toml proto/Cargo.toml
COPY downloader_client/Cargo.toml downloader_client/Cargo.toml
RUN mkdir -p bot/src && echo "fn main(){}" > bot/src/main.rs
RUN mkdir -p downloader_client/src && echo "fn main(){}" > downloader_client/src/main.rs
RUN mkdir -p proto/src && echo "" > proto/src/lib.rs
RUN cargo fetch --manifest-path bot/Cargo.toml
RUN cargo fetch --manifest-path downloader_client/Cargo.toml
RUN cargo fetch --manifest-path proto/Cargo.toml

COPY proto proto
RUN touch proto/src/lib.rs

RUN cargo build --release --target x86_64-unknown-linux-musl --manifest-path proto/Cargo.toml --target-dir target

COPY downloader_client downloader_client
RUN touch downloader_client/src/main.rs

RUN cargo build --release --target x86_64-unknown-linux-musl --manifest-path downloader_client/Cargo.toml --target-dir target

COPY bot bot
RUN touch bot/src/main.rs

RUN cargo build --release --target x86_64-unknown-linux-musl --manifest-path bot/Cargo.toml --target-dir target

RUN upx --best --lzma target/x86_64-unknown-linux-musl/release/bot

FROM base AS final
WORKDIR /app
COPY --from=build /usr/src/app/target/x86_64-unknown-linux-musl/release/bot /app/bot
ENV RUST_BACKTRACE=full
ENTRYPOINT ["/app/bot"]
