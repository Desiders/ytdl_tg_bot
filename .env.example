# Required.
# Telegram API ID. Take it from https://my.telegram.org/apps
TELEGRAM_API_ID=
# Required.
# Telegram API hash. Take it from https://my.telegram.org/apps
TELEGRAM_API_HASH=

# Required.
# RAM memory limit for the bot in container.
# Most of these options take a positive integer, followed by a suffix of b, k, m, g, to indicate bytes, kilobytes, megabytes, or gigabytes.
BOT_MEM_LIMIT=

# Required
POSTGRES_PASSWORD=
# Optional.
# Default: `$USER`
POSTGRES_USER=
# Optional.
# Default: `$USER`
POSTGRES_DB=api
# Optional.
# Default: `5432`
POSTGRES_PORT=5432

# Optional.
# Default: `8080`
YT_TOOLKIT_PORT=8080

# Optional.
# Default: `4416`
YT_POT_PROVIDER_PORT=4416

# Optional.
# Default: `8081`
TELEGRAM_BOT_API_PORT=8081

# Optional.
# Default: `8428`
VICTORIA_METRICS_PORT=8428

# Optional.
# Default: `3000`
GRAFANA_PORT=3000

# Required in `migration` service of compose.
# Database connection string for migrations.
# You can use "127.0.0.1" if the database is running on the same network.
# If the database is running in docker, you can use the database container name as the host: "postgres"
DATABASE_URL=postgres://POSTGRES_USER:POSTGRES_PASSWORD@postgres/POSTGRES_DB?sslmode=disable

# Required in `grafana` service of compose.
# You can use "127.0.0.1" if the victoria metrics is running on the same network.
# If the victoria metrics is running in docker, you can use the database container name as the host: "victoria_metrics"
VICTORIA_METRICS_URL=http://victoria_metrics:8428

# Required in `victoria_metrics` service of compose.
# You can use "127.0.0.1" if the victoria metrics is running on the same network.
# If the victoria metrics is running in docker, you can use the database container name as the host: "victoria_metrics"
VMAGENT_REMOTE_WRITE_URL=http://victoria_metrics:8428/api/v1/write
# Required in `victoria_metrics` service of compose
VMAGENT_REMOTE_WRITE_USER=admin
# Required in `victoria_metrics` service of compose
VMAGENT_REMOTE_WRITE_PASSWORD=admin

# Required in `grafana` service of compose.
GRAFANA_USER=admin
# Required in `grafana` service of compose.
GRAFANA_PASSWORD=admin
# Required in `grafana` service of compose.
# You can change access to dashboards for unathorized users.
GRAFANA_ANONYMOUS_ENABLED=true
